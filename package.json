{
  "name": "emsd",
  "version": "0.1.0",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "build": "bun run build:core && bun run build:daemon && bun run build:cli && bun run web:build",
    "build:core": "bun run --cwd packages/core build",
    "build:daemon": "bun run --cwd apps/daemon build",
    "build:cli": "bun run --cwd apps/cli build",
    "typecheck": "bun run typecheck:core && bun run typecheck:daemon && bun run typecheck:cli && bun run typecheck:web",
    "typecheck:core": "bun run --cwd packages/core typecheck",
    "typecheck:daemon": "bun run --cwd apps/daemon typecheck",
    "typecheck:cli": "bun run --cwd apps/cli typecheck",
    "typecheck:web": "bun run --cwd apps/web typecheck",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "bun run test:core && bun run test:daemon && bun run test:cli",
    "test:core": "bun run --cwd packages/core test",
    "test:daemon": "bun run --cwd apps/daemon test",
    "test:cli": "bun run --cwd apps/cli test",
    "daemon:dev": "bun run --cwd apps/daemon dev",
    "daemon:start": "bun run scripts/start-daemon.ts",
    "daemon:stop": "bun run scripts/stop-daemon.ts",
    "daemon:start:pm2": "pm2 start ecosystem.config.cjs --only emsd",
    "daemon:stop:pm2": "pm2 delete emsd",
    "daemon:logs:pm2": "pm2 logs emsd",
    "cli": "bun run --cwd apps/cli cli --",
    "battery:list": "bun run --cwd apps/cli cli -- battery list",
    "web:dev": "bun run --cwd apps/web dev",
    "web:build": "bun run --cwd apps/web build",
    "web:start": "bun run --cwd apps/web start"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.23",
    "@types/react": "^19.1.4",
    "@types/react-dom": "^19.1.5",
    "bun-types": "^1.3.11",
    "pm2": "^5.4.3",
    "typescript": "^5.8.3"
  }
}
