# daemon...

# optional: override the default SQLite database path
# EMSD_DB_PATH=data/emsd.sqlite

# optional: get from https://developer.tibber.com/settings/access-token
TIBBER_ACCESS_TOKEN=
# optional: set this when the Tibber account has multiple homes and you want a specific one
TIBBER_HOME_ID=

# optional: required for some Enphase local API setups
ENPHASE_ENLIGHTEN_USERNAME=

ENPHASE_ENLIGHTEN_PASSWORD=


# web...

PORT=3300
NEXTAUTH_SECRET=replace-with-a-strong-secret
EMSD_ADMIN_PASSWORD=replace-with-a-strong-password
AUTH_TRUST_HOST=true
# optional: set to use a fixed bearer token for the local API at /api/local/v1/current
EMSD_LOCAL_API_TOKEN=

