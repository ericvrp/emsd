# get from https://developer.tibber.com/settings/access-token
TIBBER_ACCESS_TOKEN=replace-with-your-tibber-access-token
# optional: set this when the Tibber account has multiple homes and you want a specific one
TIBBER_HOME_ID=

# required for Enphase local API access on newer firmware that requires owner auth
ENPHASE_ENLIGHTEN_USERNAME=
ENPHASE_ENLIGHTEN_PASSWORD=

